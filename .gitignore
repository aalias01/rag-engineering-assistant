# Private local folders — never pushed to GitHub
# Convention: any folder ending in _local/ is gitignored.
**/*_local/

# API key — NEVER commit
.env

# Engineering PDFs — download instructions in README
# Committed: data/eval/test_queries.jsonl (ground truth, no PII)
data/documents/
*.pdf

# ChromaDB vector store.
# The PRODUCTION store (single `engineering_docs` collection, ~40 MB) is COMMITTED
# on purpose so the deployed instance ships with its vectors — no re-embedding at
# deploy time. Rebuildable anytime via `python -m src.ingestion`.
# See docs/deployment_notes.md. (chroma_db/ intentionally NOT ignored.)
chroma_store/

# LangSmith trace cache
.langsmith/

# Jupyter artifacts
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Environment
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# HuggingFace model cache (cross-encoder reranker download)
# These are auto-downloaded at runtime — don't commit
.cache/

# Ingestion hash store — local state, rebuilt on ingest
data/eval/ingested_hashes.json
