# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual key.
#
# Usage in Python: from dotenv import load_dotenv; load_dotenv()

# Required — OpenAI API key for embeddings (text-embedding-3-small) and
# generation (gpt-4o-mini). Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional — set to "true" to enable LangSmith tracing (free tier).
# Traces every query → retrieved chunks → LLM call → answer.
# Get a key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=rag-engineering-assistant

# Optional — set to "ollama" to use a local Llama 3 model instead of OpenAI.
# Requires Ollama installed and running: https://ollama.com
# Run: ollama pull llama3.1:8b
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ChromaDB path — where the vector store is persisted locally.
# Do not change unless you move the chroma_db directory.
CHROMA_PERSIST_PATH=./chroma_db

# Optional — comma-separated list of additional allowed CORS origins for the API.
# Set this in Render (production) to the deployed Vercel frontend URL, e.g.:
#   FRONTEND_ORIGIN=https://your-app.vercel.app
# Local dev origins (localhost:3000/8080, 127.0.0.1:5500) are always allowed.
FRONTEND_ORIGIN=
