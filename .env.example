# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.
#
# Usage in Python: from dotenv import load_dotenv; load_dotenv()

# ---------------------------------------------------------------------------
# GENERATION — the LLM that writes the answer (this is the real cost driver).
# LLM_PROVIDER selects it:
#   "groq"   → FREE. OpenAI-compatible, no credit card. Recommended for the
#              public demo. Create a key at https://console.groq.com (API Keys).
#   "openai" → paid, ~$0.02 / 100 queries. Uses gpt-4o-mini.
#   "ollama" → free but LOCAL ONLY (needs ~5-8 GB RAM); won't run on free
#              cloud hosts. Handy for offline dev on your Mac.
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq

# Groq — required when LLM_PROVIDER=groq. Free tier, no card.
GROQ_API_KEY=your-groq-api-key-here
# Pick any current model from https://console.groq.com/docs/models
# (model IDs change; openai/gpt-oss-20b is a fast, capable default).
GROQ_MODEL=openai/gpt-oss-20b

# ---------------------------------------------------------------------------
# EMBEDDINGS — used to index the docs and synthesized-path queries.
# EMBEDDING_PROVIDER selects it:
#   "openai" → text-embedding-3-small (default). Needs OPENAI_API_KEY below.
#              Cost is negligible (~$0.02 / 1M tokens) but NOT zero, and this
#              key stays live in production because interpretation queries are embedded.
#   "local"  → all-MiniLM-L6-v2, fully free/offline. Switching is a migration:
#              it changes vector size, so you must re-run ingestion. See README.
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai

# OpenAI — required for embeddings (unless EMBEDDING_PROVIDER=local), and for
# generation only when LLM_PROVIDER=openai. https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Model override when LLM_PROVIDER=openai (optional).
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# RETRIEVAL config. On memory-constrained hosts (Render free tier = 512 MB),
# set USE_RERANKER=false: the cross-encoder reranker pulls in torch (~700 MB)
# and the project's own ablation found it didn't improve results. Dense + BM25
# hybrid is lightweight and needs no torch.
# ---------------------------------------------------------------------------
USE_HYBRID=true
USE_RERANKER=true
TOP_K=4

# ---------------------------------------------------------------------------
# Optional — LangSmith tracing (free tier). Traces query → chunks → LLM → answer.
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=rag-engineering-assistant

# Optional — local Llama via Ollama (dev only; requires Ollama running).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ChromaDB path — where the vector store is persisted locally.
CHROMA_PERSIST_PATH=./chroma_db

# CORS — set to the deployed frontend URL in production, e.g.:
#   FRONTEND_ORIGIN=https://your-app.vercel.app
# Local dev origins (localhost:3000/8080, 127.0.0.1:5500) are always allowed.
FRONTEND_ORIGIN=

# ---------------------------------------------------------------------------
# v2 — Intent routing + deterministic facts path + citation validation
# ---------------------------------------------------------------------------
# Master switch. Off = exact v1 behavior (retrieve + generate for everything).
ROUTER_ENABLED=true

# Intent classifier backend:
#   zero_shot — few-shot prompt via INTENT_PROVIDER
#   local     — fine-tuned DistilBERT (train with scripts/train_intent_classifier.py)
#   rules     — deterministic keyword baseline, no API/model needed
# Any failure falls open to rules → interpret, so a dead API never breaks queries.
INTENT_CLASSIFIER=zero_shot
INTENT_PROVIDER=groq
# INTENT_GROQ_MODEL=openai/gpt-oss-20b
# INTENT_OPENAI_MODEL=gpt-4o-mini
# INTENT_MODEL_PATH=./models/intent_distilbert

# Typed facts files directory (JSON, schema-validated at load).
FACTS_DIR=./data/facts

# Post-generation citation validation on the synthesized path:
#   flag   — attach the report; frontend shows a warning badge (default)
#   strict — fabricated citations / ungrounded numbers become refusals (POST /query only)
#   off    — v1 behavior
VALIDATOR_MODE=flag
